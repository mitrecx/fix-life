@import "../../styles/common.wxss";

.login-page {
  padding-top: 80rpx;
}

.hero {
  text-align: center;
  padding: 56rpx var(--space-card);
  margin-bottom: 32rpx;
}

.brand {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.tagline {
  display: block;
  margin-top: 16rpx;
  font-size: var(--font-caption);
  opacity: 0.9;
}

.login-card .section-desc {
  margin-bottom: 40rpx;
}

.login-btn {
  margin-top: 8rpx;
}

.error {
  display: block;
  margin-top: 24rpx;
  text-align: center;
  color: var(--color-danger);
  font-size: var(--font-caption);
}
