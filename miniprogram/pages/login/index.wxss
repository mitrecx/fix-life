@import "../../styles/common.wxss";

.login-page {
  padding-top: 48rpx;
}

.login-header {
  text-align: center;
  padding: 24rpx var(--space-page) 40rpx;
}

.brand {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: var(--color-text);
  letter-spacing: 2rpx;
}

.tagline {
  display: block;
  margin-top: 12rpx;
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
}

.login-card .section-desc {
  margin-bottom: 40rpx;
}

.login-btn {
  margin-top: 8rpx;
}

.error {
  display: block;
  margin-top: 24rpx;
  text-align: center;
  color: var(--color-danger);
  font-size: var(--font-caption);
}
