<view class="page-shell login-page">
  <view class="login-header">
    <text class="brand">FixLife</text>
    <text class="tagline">待办 · 每日进度 · 随手记录</text>
  </view>

  <view class="card login-card">
    <text class="section-title">欢迎使用</text>
    <text class="section-desc">微信登录后，可与 Web 端数据同步（绑定账号后完全互通）。</text>
    <button class="primary-btn login-btn" loading="{{loading}}" bindtap="handleLogin">微信一键登录</button>
    <text class="error" wx:if="{{error}}">{{error}}</text>
  </view>
</view>
