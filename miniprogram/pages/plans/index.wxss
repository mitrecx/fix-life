@import "../../styles/common.wxss";

.card {
  margin-top: 0;
  margin-bottom: 16rpx;
}

.filter-label {
  font-size: var(--font-body);
  font-weight: 600;
  color: var(--color-text);
}

.year-nav {
  display: flex;
  gap: 16rpx;
  margin: 16rpx 0;
}

.picker-text {
  padding: 12rpx 0;
  color: var(--color-text-secondary);
  font-size: var(--font-caption);
}

.field {
  margin-top: 20rpx;
}

.plan-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  flex: 1;
  margin-right: 16rpx;
}

.plan-meta {
  display: block;
  margin-top: 10rpx;
}

.plan-item .progress-bar {
  margin-top: 16rpx;
}
