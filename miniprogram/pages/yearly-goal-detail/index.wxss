@import "../../styles/common.wxss";

.field {
  margin-top: 16rpx;
}

.progress-bar {
  height: 12rpx;
  background: #e5e7eb;
  border-radius: 999rpx;
  margin: 12rpx 0;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #4f46e5;
}

.milestone {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}
