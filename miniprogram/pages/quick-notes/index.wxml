<view class="quick-notes-page">
  <view class="notes-scroll-wrap">
    <scroll-view
      class="notes-scroll"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      scroll-into-view="{{scrollIntoView}}"
      scroll-with-animation="{{false}}"
      upper-threshold="120"
      bindscrolltoupper="onScrollToUpper"
      bindscroll="onNotesScroll"
    >
      <view id="notes-list-inner" class="notes-list-inner">
        <view class="load-more-hint" wx:if="{{loadingMore}}">
          <text class="muted">加载中...</text>
        </view>
        <view class="load-more-hint" wx:elif="{{hasMoreOlder && !loading}}">
          <text class="muted">上滑加载更早记录</text>
        </view>

        <view class="card" wx:if="{{loading && notes.length === 0}}">
          <text class="muted">加载中...</text>
        </view>

        <view class="card empty" wx:elif="{{!loading && notes.length === 0}}">
          <text class="muted">{{searchQ ? '没有匹配的记录' : '暂无随手记'}}</text>
        </view>

        <block wx:else>
          <block wx:for="{{notes}}" wx:key="id">
            <view class="time-divider" wx:if="{{item.dateDivider}}">
              <view class="time-divider-line" />
              <text class="time-divider-text date">{{item.dateDivider}}</text>
              <view class="time-divider-line" />
            </view>
            <view class="card note" id="note-{{item.id}}">
              <view class="time-divider">
                <view class="time-divider-line" />
                <text class="time-divider-text">{{item.messageTime}}</text>
                <view class="time-divider-line" />
              </view>
              <view class="note-body">
              <block wx:for="{{item.segments}}" wx:for-item="seg" wx:for-index="segIndex" wx:key="segIndex">
                <view wx:if="{{seg.type === 'markdown'}}" class="note-rich-wrap">
                  <rich-text class="note-rich note-rich-visual" nodes="{{seg.html}}" />
                  <text class="note-rich-select" selectable>{{seg.plain}}</text>
                </view>
                <image
                  wx:elif="{{seg.type === 'image'}}"
                  class="note-image"
                  src="{{seg.src}}"
                  mode="widthFix"
                  show-menu-by-longpress
                  lazy-load
                  data-id="{{item.id}}"
                  data-src="{{seg.src}}"
                  bindtap="previewImage"
                />
              </block>
            </view>
            </view>
          </block>
        </block>

        <view id="notes-bottom-anchor" class="list-bottom-spacer"></view>
      </view>
    </scroll-view>

    <view
      wx:if="{{showSearch && searchPanelVisible && !searchClosing}}"
      class="search-dismiss-mask"
      catchtap="dismissSearchAndQuery"
      catchtouchmove="preventTouchMove"
    />

    <view class="search-header">
      <view
        class="search-toggle"
        bindtap="toggleSearch"
        bindtouchstart="onSearchTouchStart"
        bindtouchend="onSearchTouchEnd"
      >
        <text class="search-chevron {{showSearch ? 'open' : ''}}">▼</text>
        <text class="search-filter-tag" wx:if="{{searchQ && !showSearch && !searchClosing}}">已筛选</text>
      </view>
      <view
        class="search-panel-wrap {{searchPanelActive ? 'active' : ''}} {{searchClosing ? 'closing' : ''}}"
        wx:if="{{searchPanelVisible}}"
      >
        <view class="search-panel" catchtap="noop">
          <view class="search-row">
            <input class="input search-input" placeholder="搜索随手记" value="{{searchQ}}" bindinput="onSearchInput" bindconfirm="onSearch" focus="{{searchFocus}}" />
            <button class="primary-btn inline-btn search-btn" bindtap="onSearch">搜</button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="composer-bar" wx:if="{{showComposer}}">
    <input
      class="input composer-input"
      placeholder="记录灵感..."
      value="{{content}}"
      bindinput="onContentInput"
      bindconfirm="handleCreate"
      confirm-type="done"
      focus="{{composerFocus}}"
    />
    <button class="primary-btn inline-btn composer-save" bindtap="handleCreate">保存</button>
    <view class="composer-close" bindtap="closeComposer">×</view>
  </view>
  <view class="compose-fab" wx:else bindtap="openComposer">
    <text class="compose-fab-icon">+</text>
  </view>
</view>
