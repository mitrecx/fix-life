@import "../../styles/common.wxss";

page {
  height: 100%;
  overflow: hidden;
}

.quick-notes-page {
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 0;
  box-sizing: border-box;
  padding-bottom: var(--tab-bar-inset);
  background: var(--color-bg);
}

.card {
  margin-top: 0;
  margin-bottom: 16rpx;
}

.search-row {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}

.search-input {
  flex: 1;
  width: 0;
}

.search-btn {
  flex-shrink: 0;
  min-width: 96rpx;
}

.notes-scroll-wrap {
  flex: 1;
  min-height: 0;
  position: relative;
}

.notes-scroll {
  height: 100%;
}

.notes-list-inner {
  padding-bottom: 16rpx;
}

.load-more-hint {
  text-align: center;
  min-height: 64rpx;
  line-height: 64rpx;
  padding: 0;
  font-size: var(--font-small);
}

.list-bottom-spacer {
  height: 8rpx;
}

.time-divider {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 8rpx 0 12rpx;
}

.time-divider-line {
  flex: 1;
  height: 1rpx;
  background: #e0e7ff;
}

.time-divider-text {
  flex-shrink: 0;
  font-size: 28rpx;
  color: #818cf8;
  line-height: 1.2;
}

.time-divider-text.date {
  font-size: 30rpx;
  color: #6366f1;
}

.card.note {
  background: #f3f4f6;
}

.note-body {
  margin-top: 12rpx;
}

.note-rich-wrap {
  position: relative;
  width: 100%;
}

.note-rich-visual {
  display: block;
  width: 100%;
  word-break: break-word;
}

.note-rich-select {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  color: rgba(0, 0, 0, 0);
  font-size: 36rpx;
  line-height: 1.65;
  white-space: pre-wrap;
  word-break: break-word;
  user-select: text;
  -webkit-user-select: text;
}

.note-rich {
  display: block;
  width: 100%;
  word-break: break-word;
  font-size: 36rpx;
  line-height: 1.65;
}

.note-image {
  display: block;
  width: 100%;
  margin: 16rpx 0;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
  background: #f9fafb;
}

.composer-bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx var(--space-page) 12rpx;
  background: var(--color-surface);
  border-top: 1rpx solid var(--color-border);
  box-sizing: border-box;
}

.composer-close {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  line-height: 52rpx;
  text-align: center;
  font-size: 40rpx;
  color: var(--color-text-muted);
}

.composer-input {
  flex: 1;
  width: 0;
  height: 72rpx;
  min-height: 72rpx;
  line-height: 72rpx;
}

.composer-save {
  flex-shrink: 0;
  min-width: 112rpx;
  height: 72rpx;
  min-height: 72rpx;
  line-height: 72rpx;
  padding: 0 24rpx !important;
}
