@import "../../styles/common.wxss";

.card {
  margin-top: 0;
  margin-bottom: 16rpx;
}

.date-card {
  padding-bottom: 20rpx;
  overflow: visible;
}

.nav-row {
  margin-bottom: 20rpx;
}

.nav-btn-wrap {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  background: var(--color-primary-light);
}

.nav-btn {
  font-size: 44rpx;
  color: var(--color-primary);
  font-weight: 300;
  line-height: 1;
}

.date-center {
  text-align: center;
  flex: 1;
}

.date-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.today-link {
  display: block;
  margin-top: 6rpx;
  font-size: var(--font-small);
}

.week-strip {
  width: 100%;
  height: 88rpx;
  margin-top: 4rpx;
}

.week-strip-inner {
  display: inline-flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: center;
  height: 88rpx;
  padding: 8rpx 0;
  box-sizing: border-box;
}

.week-day {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 92rpx;
  height: 72rpx;
  margin-right: 12rpx;
  border-radius: var(--radius-md);
  background: #f9fafb;
  border: 1rpx solid var(--color-border-light);
  font-size: var(--font-small);
  color: var(--color-text-secondary);
  flex-shrink: 0;
  box-sizing: border-box;
}

.week-day.selected {
  background: var(--btn-primary-bg);
  color: var(--color-primary);
  border-color: var(--btn-primary-border);
  font-weight: 600;
}

.week-day.today:not(.selected) {
  border-color: #a5b4fc;
  color: var(--color-primary);
}

.summary-text {
  display: block;
  margin: 16rpx 0;
  color: #374151;
  white-space: pre-wrap;
  line-height: 1.6;
  font-size: var(--font-caption);
}

.summary-edit {
  display: inline-block;
  margin-top: 8rpx;
}

.action-row {
  margin-top: 20rpx;
}

.schedule-btn {
  margin: 0;
  width: 100%;
}

.entry-row {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.status-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #d1d5db;
  flex-shrink: 0;
  margin-top: 4rpx;
  box-sizing: border-box;
}

.status-dot.in-progress {
  border-color: var(--color-primary);
  background: var(--color-primary-light);
}

.status-dot.done {
  border-color: #10b981;
  background: #ecfdf5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  font-size: 26rpx;
  color: #10b981;
  line-height: 1;
  font-weight: 700;
}

.entry-body {
  flex: 1;
  min-width: 0;
}

.entry-title {
  font-size: 30rpx;
  font-weight: 500;
  line-height: 1.45;
  color: var(--color-text);
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
  align-items: center;
}

.status-label {
  font-size: var(--font-small);
}

.delete-link {
  color: var(--color-danger);
  font-size: var(--font-small);
  padding: 8rpx;
  flex-shrink: 0;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(17, 24, 39, 0.4);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.modal-panel {
  width: 100%;
  max-height: 72vh;
  background: var(--color-surface);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: 16rpx var(--space-card) var(--space-card);
  border-top: 1rpx solid var(--color-border);
}

.modal-handle {
  width: 64rpx;
  height: 8rpx;
  background: #d1d5db;
  border-radius: var(--radius-full);
  margin: 0 auto 20rpx;
}

.modal-header {
  margin-bottom: 16rpx;
}

.modal-list {
  max-height: 55vh;
}

.modal-item {
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
  font-size: var(--font-body);
  color: var(--color-text);
}

.modal-item:active {
  opacity: 0.7;
}

.modal-body {
  padding: 48rpx 0;
}
