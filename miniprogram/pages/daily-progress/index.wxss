@import "../../styles/common.wxss";

page {
  height: 100%;
  overflow: hidden;
}

.daily-page {
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 0;
  box-sizing: border-box;
  padding-bottom: var(--tab-bar-inset);
  background: var(--color-bg);
}

.daily-scroll-wrap {
  flex: 1;
  min-height: 0;
  position: relative;
}

.daily-scroll {
  height: 100%;
}

.daily-list-inner {
  padding-bottom: 16rpx;
}

.toolbar .filter-chip {
  font-size: var(--font-caption);
  padding: 12rpx 22rpx;
}

.card {
  margin-top: 0;
  margin-bottom: 16rpx;
}

.date-bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 0 var(--space-page) 12rpx;
  padding: 8rpx 0;
}

.date-nav-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  background: var(--color-primary-light);
  flex-shrink: 0;
}

.date-nav-icon {
  font-size: 36rpx;
  color: var(--color-primary);
  font-weight: 300;
  line-height: 1;
}

.date-center {
  flex: 1;
  text-align: center;
  min-width: 0;
}

.date-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.3;
}

.today-link {
  display: block;
  margin-top: 4rpx;
  font-size: var(--font-small);
  color: var(--color-primary);
}

.summary-text {
  display: block;
  margin: 16rpx 0;
  color: #374151;
  white-space: pre-wrap;
  line-height: 1.6;
  font-size: var(--font-caption);
}

.summary-edit {
  display: inline-block;
  margin-top: 8rpx;
}

.entry-row {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.entry-swipe-wrap {
  position: relative;
  overflow: hidden;
  padding: 0;
}

.entry-swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 160rpx;
  display: flex;
  align-items: stretch;
  justify-content: center;
  background: var(--color-danger);
}

.entry-swipe-delete {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: var(--font-caption);
}

.entry-swipe-body {
  position: relative;
  z-index: 1;
  padding: var(--space-card);
  background: var(--color-surface);
  transition: transform 0.22s ease;
}

.entry-swipe-body.dragging {
  transition: none;
}

.status-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #d1d5db;
  flex-shrink: 0;
  margin-top: 4rpx;
  box-sizing: border-box;
}

.status-dot.in-progress {
  border-color: var(--color-primary);
  background: var(--color-primary-light);
}

.status-dot.done {
  border-color: #10b981;
  background: #ecfdf5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  font-size: 26rpx;
  color: #10b981;
  line-height: 1;
  font-weight: 700;
}

.entry-body {
  flex: 1;
  min-width: 0;
}

.entry-title {
  font-size: 30rpx;
  font-weight: 500;
  line-height: 1.45;
  color: var(--color-text);
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
  align-items: center;
}

.progress-label {
  font-size: var(--font-small);
  color: var(--color-primary);
  font-weight: 600;
}
