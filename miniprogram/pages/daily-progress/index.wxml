<view class="daily-page tab-page">
  <view class="date-bar">
    <view class="date-nav-btn" bindtap="onPrevDay"><text class="date-nav-icon">‹</text></view>
    <view class="date-center" bindtap="onGoToday">
      <text class="date-title">{{displayDate}}</text>
      <text class="today-link" wx:if="{{!isToday}}">返回今天</text>
    </view>
    <view class="date-nav-btn" bindtap="onNextDay"><text class="date-nav-icon">›</text></view>
  </view>

  <view class="card summary-card" wx:if="{{showDailySummary && summaryPreview}}">
    <text class="section-title">每日总结</text>
    <text class="summary-text">{{summaryPreview}}</text>
    <text class="link-btn summary-edit" bindtap="openSummary">编辑总结</text>
  </view>

  <view class="daily-scroll-wrap">
    <scroll-view
      class="daily-scroll"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      refresher-enabled
      refresher-triggered="{{refreshing}}"
      bindrefresherrefresh="onScrollRefresh"
      bindscroll="onDailyScroll"
    >
      <view class="daily-list-inner">
        <view class="card" wx:if="{{loading}}">
          <text class="muted">加载中...</text>
        </view>

        <view class="empty card" wx:elif="{{entries.length === 0}}">
          <text>今日暂无任务</text>
        </view>

        <block wx:else>
          <view class="card entry entry-swipe-wrap" wx:for="{{entries}}" wx:key="id">
            <view class="entry-swipe-actions">
              <view class="entry-swipe-delete" data-id="{{item.id}}" catchtap="handleDeleteEntry">删除</view>
            </view>
            <view
              class="entry-swipe-body {{swipingId === item.id ? 'dragging' : ''}}"
              style="transform: translateX({{swipingId === item.id ? swipeOffset : (openSwipeId === item.id ? -deleteRevealPx : 0)}}px);"
              data-id="{{item.id}}"
              bindtouchstart="onEntrySwipeStart"
              bindtouchmove="onEntrySwipeMove"
              bindtouchend="onEntrySwipeEnd"
              bindtouchcancel="onEntrySwipeEnd"
            >
              <view class="entry-row">
                <view class="status-dot {{item.status}}" data-id="{{item.id}}" data-status="{{item.status}}" catchtap="handleToggleStatus">
                  <text wx:if="{{item.status === 'done'}}" class="check-icon">✓</text>
                </view>
                <view class="entry-body" data-id="{{item.id}}" bindtap="openEntryDetail">
                  <text class="entry-title">{{item.title}}</text>
                  <view class="meta-row">
                    <text class="badge" style="background:{{item.contextColor}}">{{item.contextLabel}}</text>
                    <text class="badge" style="background:{{item.priorityColor}}">{{item.priorityLabel}}</text>
                    <text class="muted status-label">{{item.statusLabel}}</text>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </block>
      </view>
    </scroll-view>

    <view
      wx:if="{{showFilter && filterPanelVisible && !filterClosing}}"
      class="search-dismiss-mask"
      catchtap="dismissFilterAndQuery"
      catchtouchmove="preventTouchMove"
    />

    <view class="search-header">
      <view
        class="search-toggle"
        bindtap="toggleFilterPanel"
        bindtouchstart="onFilterTouchStart"
        bindtouchend="onFilterTouchEnd"
      >
        <text class="search-chevron {{showFilter ? 'open' : ''}}">▼</text>
        <text class="search-filter-tag" wx:if="{{filterActive && !showFilter && !filterClosing}}">已筛选</text>
      </view>
      <view
        class="search-panel-wrap daily-search {{filterPanelActive ? 'active' : ''}} {{filterClosing ? 'closing' : ''}}"
        wx:if="{{filterPanelVisible}}"
      >
        <view class="search-panel toolbar" catchtap="noop">
          <view class="filter-bar">
            <text class="chip filter-chip {{contextFilter === 'all' ? 'active' : 'inactive'}}" data-value="all" bindtap="onContextFilter">全部</text>
            <text wx:for="{{contexts}}" wx:key="value" class="chip filter-chip {{contextFilter === item.value ? 'active' : 'inactive'}}" data-value="{{item.value}}" bindtap="onContextFilter">{{item.label}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
