<view class="page-shell bind-page">
  <view class="card hero-gradient intro-card">
    <text class="section-title">绑定 Web 账号</text>
    <text class="section-desc">在 Web 个人中心生成绑定码，输入后即可与 fixlife.mitrecx.top 共用数据。</text>
  </view>

  <view class="card bound-card" wx:if="{{isBound}}">
    <text class="bound-title">已绑定</text>
    <text class="bound-user">@{{user.username}}</text>
    <text class="section-desc">小程序与 Web 数据已同步</text>
  </view>

  <block wx:else>
    <view class="card card-flat">
      <text class="section-title">输入绑定码</text>
      <input class="input code-input field" type="number" maxlength="6" placeholder="6 位数字" value="{{bindCode}}" bindinput="onCodeInput" />
      <button class="primary-btn" loading="{{loading}}" bindtap="handleBind">确认绑定</button>
    </view>

    <view class="card card-flat steps-card">
      <text class="section-title">操作步骤</text>
      <view class="step-item"><text class="step-num">1</text><text class="step-text">浏览器登录 fixlife.mitrecx.top</text></view>
      <view class="step-item"><text class="step-num">2</text><text class="step-text">个人中心 → 小程序绑定 → 生成绑定码</text></view>
      <view class="step-item"><text class="step-num">3</text><text class="step-text">10 分钟内在此输入并确认</text></view>
    </view>
  </block>
</view>
