<view class="card profile">
  <view class="avatar-row" bindtap="handleChooseAvatar">
    <image wx:if="{{user.avatar_url}}" class="avatar" src="{{user.avatar_url}}" mode="aspectFill" />
    <view wx:else class="avatar placeholder">修</view>
    <view class="profile-info">
      <text class="name">{{user.full_name || user.username || '用户'}}</text>
      <text class="meta">{{user.username}}</text>
      <text class="meta" wx:if="{{user.email}}">{{user.email}}</text>
    </view>
  </view>
  <text class="bio muted" wx:if="{{user.bio && !showEdit}}">{{user.bio}}</text>
  <view wx:if="{{showEdit}}" class="edit-form">
    <input class="input field" placeholder="显示名称" value="{{editName}}" bindinput="onNameInput" />
    <textarea class="textarea field" placeholder="个人简介" value="{{editBio}}" bindinput="onBioInput" maxlength="-1" />
    <button class="primary-btn" bindtap="handleSaveProfile">保存资料</button>
  </view>
  <button wx:else class="secondary-btn edit-btn" bindtap="toggleEdit">编辑资料</button>
</view>

<view class="card menu">
  <view class="menu-item" wx:if="{{canQuickNotes}}" data-url="/pages/quick-notes/index" bindtap="navigate">
    <text>随手记</text>
    <text class="muted">›</text>
  </view>
  <view class="menu-item" data-url="/pages/weekly-summaries/index" bindtap="navigate">
    <text>周总结</text>
    <text class="muted">›</text>
  </view>
  <view class="menu-item" data-url="/pages/settings/index" bindtap="navigate">
    <text>系统设置</text>
    <text class="muted">›</text>
  </view>
  <view class="menu-item" wx:if="{{canAdmin}}" data-url="/pages/admin-users/index" bindtap="navigate">
    <text>用户管理</text>
    <text class="muted">›</text>
  </view>
</view>

<view class="card">
  <button class="logout-btn" bindtap="handleLogout">退出登录</button>
</view>
