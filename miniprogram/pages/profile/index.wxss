@import "../../styles/common.wxss";

.profile-page .card {
  margin-top: 0;
  margin-bottom: 16rpx;
}

.profile-hero {
  padding: 40rpx var(--space-card) 36rpx;
}

.avatar-row {
  display: flex;
  gap: 24rpx;
  align-items: center;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  flex-shrink: 0;
  border: 2rpx solid var(--color-border-light);
}

.avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3f4f6;
  color: var(--color-primary);
  font-size: 48rpx;
  font-weight: 600;
}

.name {
  font-size: 40rpx;
  font-weight: 600;
  display: block;
  color: var(--color-text);
}

.meta {
  display: block;
  font-size: var(--font-caption);
  margin-top: 6rpx;
  color: var(--color-text-secondary);
}

.bio {
  display: block;
  margin-top: 24rpx;
  font-size: var(--font-caption);
  line-height: 1.6;
  color: var(--color-text-secondary);
}

.field {
  margin-top: 20rpx;
}

.edit-card {
  padding: 20rpx var(--space-card);
}

.edit-btn {
  width: 100%;
}

.bind-hint {
  color: var(--color-primary);
  font-size: var(--font-small);
  font-weight: 500;
  background: var(--color-primary-light);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
}

.logout-card {
  padding: 20rpx var(--space-card);
  margin-bottom: 32rpx;
}

.logout-btn {
  width: 100%;
}

.menu-list {
  padding: 0;
}
