@import "../../styles/common.wxss";

page {
  min-height: 100%;
  background: var(--color-bg);
}

.task-detail-shell {
  min-height: 100vh;
  box-sizing: border-box;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 120;
  box-sizing: border-box;
  background: #ffffff;
  border-bottom: 1rpx solid var(--color-border-light);
}

.custom-nav-bar {
  position: relative;
  display: flex;
  align-items: center;
  padding: 0 8rpx;
}

.nav-back-hit {
  min-width: 112rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding-left: 12rpx;
}

.nav-back-hit-active {
  opacity: 0.6;
}

.nav-back-icon {
  font-size: 52rpx;
  font-weight: 300;
  line-height: 1;
  color: #111827;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  max-width: 52%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
}

.task-detail-page {
  min-height: 100vh;
  box-sizing: border-box;
}

.task-detail-body {
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.field {
  margin-top: 16rpx;
}

.label {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.progress-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.progress-badge {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary);
  background: var(--color-primary-light);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
}

.progress-slider-wrap {
  margin-top: 16rpx;
  padding: 18rpx 11rpx;
}

.progress-track {
  position: relative;
  height: 16rpx;
  border-radius: var(--radius-full);
  background: #e0e7ff;
  overflow: visible;
}

.progress-track-fill {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  border-radius: var(--radius-full);
  background: linear-gradient(90deg, #a5b4fc 0%, #6366f1 100%);
  box-shadow: 0 2rpx 10rpx rgba(99, 102, 241, 0.28);
  pointer-events: none;
}

.progress-thumb {
  position: absolute;
  top: 50%;
  width: 22rpx;
  height: 22rpx;
  margin-left: -11rpx;
  transform: translateY(-50%);
  border-radius: 50%;
  background: #6366f1;
  border: 2rpx solid #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(99, 102, 241, 0.4);
  pointer-events: none;
}

.schedule-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.schedule-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.schedule-title {
  margin-top: 0;
}

.schedule-open-btn {
  margin: 0;
  flex-shrink: 0;
}

.schedule-dates {
  margin-top: 12rpx;
}

.schedule-date-line {
  display: block;
  font-size: var(--font-caption);
  line-height: 1.8;
  color: var(--color-text);
}

.schedule-empty {
  display: block;
  margin-top: 12rpx;
  font-size: var(--font-caption);
}

.task-detail-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  padding: 16rpx var(--space-page);
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(249, 250, 251, 0.96);
  border-top: 1rpx solid var(--color-border-light);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.form-actions {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}

.form-actions .save-btn {
  flex: 1;
  margin: 0;
}

.form-actions .delete-btn {
  flex-shrink: 0;
  min-width: 112rpx;
  width: auto;
  padding: 22rpx 24rpx;
  margin: 0;
}
