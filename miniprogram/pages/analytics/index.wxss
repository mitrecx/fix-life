@import "../../styles/common.wxss";

.card {
  margin-top: 0;
  margin-bottom: 16rpx;
}

.tabs .tab-item {
  padding: 16rpx 0;
  font-size: var(--font-small);
}

.filter-label {
  font-size: var(--font-body);
  font-weight: 600;
}

.year-nav {
  display: flex;
  gap: 16rpx;
  margin: 16rpx 0;
}

.picker-text {
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
}

.stat-grid-wrap {
  padding-bottom: 8rpx;
}

.highlight-card {
  text-align: center;
  padding: 40rpx var(--space-card);
}

.big-rate {
  display: block;
  font-size: 72rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #6366f1, #9333ea);
  -webkit-background-clip: text;
  color: var(--color-primary);
  margin-top: 12rpx;
}

.stat-line {
  display: block;
  margin-top: 8rpx;
}

.list-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: var(--font-caption);
}
