@import "../../styles/common.wxss";

page {
  height: 100%;
  overflow: hidden;
}

.todos-page {
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 0;
  box-sizing: border-box;
  padding-bottom: var(--tab-bar-inset);
  background: var(--color-bg);
}

.tabs-header {
  flex-shrink: 0;
  background: var(--color-bg);
}

.todos-page .tabs {
  margin: 0 var(--space-page) 12rpx;
  border-top: none;
  border-radius: 0 0 var(--radius-md) var(--radius-md);
}

.todos-scroll-wrap {
  flex: 1;
  min-height: 0;
  position: relative;
}

.todos-scroll {
  height: 100%;
}

.todos-list-inner {
  padding-bottom: 16rpx;
}

.card {
  margin-top: 0;
  margin-bottom: 16rpx;
}

.toolbar {
  margin-top: 0;
}

.toolbar .filter-chip {
  font-size: var(--font-caption);
  padding: 12rpx 22rpx;
}

.search-row {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}

.search-input {
  flex: 1;
  width: 0;
}

.search-btn {
  flex-shrink: 0;
  min-width: 120rpx;
}

.task-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.task-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text);
  line-height: 1.45;
}

.progress-tag {
  font-size: var(--font-small);
  color: var(--color-primary);
  background: var(--color-primary-light);
  padding: 6rpx 14rpx;
  border-radius: var(--radius-full);
  font-weight: 600;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
  margin-top: 16rpx;
}

.schedule {
  font-size: var(--font-small);
}

.action-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.action-btn {
  margin: 0;
}
