@import "../../styles/common.wxss";

page {
  height: 100%;
  overflow: hidden;
}

.todos-page {
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 0;
  box-sizing: border-box;
  padding-bottom: var(--tab-bar-inset);
  background: var(--color-bg);
}

.tabs-header {
  flex-shrink: 0;
  background: var(--color-bg);
}

.todos-page .tabs {
  margin: 0 var(--space-page) 12rpx;
  border-top: none;
  border-radius: 0 0 var(--radius-md) var(--radius-md);
}

.todos-scroll-wrap {
  flex: 1;
  min-height: 0;
  position: relative;
}

.todos-scroll {
  height: 100%;
}

.todos-list-inner {
  padding-bottom: 16rpx;
}

.card {
  margin-top: 0;
  margin-bottom: 16rpx;
}

.toolbar {
  margin-top: 0;
}

.toolbar .filter-chip {
  font-size: var(--font-caption);
  padding: 12rpx 22rpx;
}

.search-row {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}

.search-input {
  flex: 1;
  width: 0;
}

.search-btn {
  flex-shrink: 0;
  min-width: 120rpx;
}

.task-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.task-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text);
  line-height: 1.45;
}

.progress-tag {
  font-size: var(--font-small);
  color: var(--color-primary);
  background: var(--color-primary-light);
  padding: 6rpx 14rpx;
  border-radius: var(--radius-full);
  font-weight: 600;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
  margin-top: 16rpx;
}

.schedule {
  font-size: var(--font-small);
}

.action-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.action-btn {
  margin: 0;
}

.schedule-sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 200;
  background: rgba(15, 23, 42, 0);
  transition: background 0.28s ease;
  pointer-events: auto;
}

.schedule-sheet-mask.active {
  background: rgba(15, 23, 42, 0.28);
}

.schedule-sheet {
  position: fixed;
  left: var(--space-page);
  right: var(--space-page);
  top: 50%;
  z-index: 201;
  transform: translateY(-46%) scale(0.96);
  opacity: 0;
  transition:
    opacity 0.28s ease,
    transform 0.28s ease;
  pointer-events: none;
}

.schedule-sheet.active {
  opacity: 1;
  transform: translateY(-50%) scale(1);
  pointer-events: auto;
}

.schedule-sheet-panel {
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.92) 0%,
    rgba(255, 255, 255, 0.78) 100%
  );
  backdrop-filter: saturate(180%) blur(24px);
  -webkit-backdrop-filter: saturate(180%) blur(24px);
  border: 1rpx solid rgba(255, 255, 255, 0.95);
  border-radius: var(--radius-lg);
  padding: 28rpx var(--space-card) 24rpx;
  box-shadow:
    0 16rpx 48rpx rgba(15, 23, 42, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.schedule-sheet-title {
  display: block;
  text-align: center;
  font-size: var(--font-body);
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

.schedule-sheet-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.schedule-nav-btn {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 40rpx;
  color: var(--color-primary);
}

.schedule-month-label {
  font-size: var(--font-body);
  font-weight: 600;
  color: var(--color-text);
}

.schedule-weekdays,
.schedule-grid {
  display: flex;
  flex-wrap: wrap;
}

.schedule-weekdays {
  margin-bottom: 8rpx;
}

.schedule-weekday,
.schedule-day {
  width: 14.2857%;
  box-sizing: border-box;
}

.schedule-weekday {
  text-align: center;
  font-size: var(--font-small);
  color: var(--color-text-muted);
  line-height: 48rpx;
}

.schedule-day {
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: var(--font-caption);
  color: var(--color-text);
  border-radius: var(--radius-full);
}

.schedule-day.other-month {
  color: var(--color-text-muted);
}

.schedule-day.today {
  color: var(--color-primary);
  font-weight: 600;
}

.schedule-day.selected {
  background: var(--color-primary);
  color: #ffffff;
  font-weight: 600;
}

.schedule-sheet-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.schedule-action-btn {
  flex: 1;
  margin: 0;
}
