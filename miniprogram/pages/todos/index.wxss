@import "../../styles/common.wxss";

.card {
  margin-top: 0;
  margin-bottom: 16rpx;
}

.toolbar,
.create-card {
  margin-top: 0;
}

.search-row {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}

.search-input {
  flex: 1;
  width: 0;
}

.search-btn {
  flex-shrink: 0;
  min-width: 120rpx;
  height: 88rpx;
  min-height: 88rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.create-toggle {
  padding-bottom: 4rpx;
}

.field {
  margin-top: 20rpx;
}

.task-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.task-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text);
  line-height: 1.45;
}

.progress-tag {
  font-size: var(--font-small);
  color: var(--color-primary);
  background: var(--color-primary-light);
  padding: 6rpx 14rpx;
  border-radius: var(--radius-full);
  font-weight: 600;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
  margin-top: 16rpx;
}

.schedule {
  font-size: var(--font-small);
}

.action-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.action-btn {
  margin: 0;
}
