/* Shared components — mirrors Web mobile: border-first, soft indigo accents */

.page-shell {
  min-height: 100vh;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.page-shell.tab-page {
  padding-bottom: calc(var(--tab-bar-inset) + 24rpx);
}

.section-title {
  font-size: var(--font-title);
  font-weight: 600;
  color: var(--color-text);
  letter-spacing: 0.2rpx;
}

.section-desc {
  display: block;
  margin-top: 8rpx;
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card {
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--space-card);
  margin: var(--space-page);
  box-shadow: var(--shadow-none);
}

.card-flat {
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--space-card);
  margin: var(--space-page);
}

.muted {
  color: var(--color-text-secondary);
  font-size: var(--font-caption);
}

.empty {
  text-align: center;
  padding: 64rpx var(--space-page);
  color: var(--color-text-muted);
  font-size: var(--font-caption);
}

/* Segment tabs (Web: bg-gray-100 p-1 rounded-lg) */
.tabs {
  display: flex;
  background: #f3f4f6;
  margin: var(--space-page);
  margin-bottom: 16rpx;
  padding: 8rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border-light);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
  border-radius: var(--radius-sm);
  transition: all 0.2s;
}

.tab-item.active {
  color: var(--color-primary);
  font-weight: 600;
  background: var(--color-surface);
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.06);
}

.input {
  display: block;
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  background: #f9fafb;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: var(--font-body);
  color: var(--color-text);
  box-sizing: border-box;
}

.textarea {
  display: block;
  width: 100%;
  min-height: 180rpx;
  line-height: 1.6;
  padding: 20rpx 24rpx;
  background: #f9fafb;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: var(--font-body);
  color: var(--color-text);
  box-sizing: border-box;
}

.input-row {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}

.input-row .input {
  flex: 1;
  width: 0;
}

.input-lg {
  height: 112rpx;
  min-height: 112rpx;
  line-height: 112rpx;
  font-size: 48rpx;
}

.input:focus,
.textarea:focus {
  border-color: #a5b4fc;
  background: var(--color-surface);
}

.chip {
  display: inline-block;
  padding: 10rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: var(--font-small);
  margin-right: 12rpx;
  margin-bottom: 8rpx;
  border: 1rpx solid transparent;
}

.chip.active {
  background: var(--color-primary-light);
  color: var(--color-primary);
  border-color: #c7d2fe;
  font-weight: 500;
}

.chip.inactive {
  background: var(--color-surface);
  color: #374151;
  border-color: var(--color-border);
}

.badge {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: var(--radius-sm);
  font-size: var(--font-small);
  color: #ffffff;
  font-weight: 500;
}

.badge-soft {
  background: var(--color-primary-light);
  color: var(--color-primary);
}

.link-btn {
  color: var(--color-primary);
  font-size: var(--font-caption);
  font-weight: 500;
}

.filter-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 4rpx;
  margin-top: 20rpx;
}

/* Buttons — reset WeChat defaults */
.btn-reset {
  margin: 0;
  padding: 0;
  background: transparent;
  border: none;
  line-height: normal;
  font-size: inherit;
}

.btn-reset::after {
  border: none;
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 22rpx 32rpx;
  background: var(--btn-primary-bg);
  color: var(--color-primary);
  border: 1rpx solid var(--btn-primary-border);
  border-radius: var(--radius-md);
  font-size: var(--font-body);
  font-weight: 600;
  box-shadow: none;
}

.primary-btn:active {
  background: var(--btn-primary-bg-active);
}

.primary-btn::after {
  border: none;
}

.primary-btn[size="mini"] {
  width: auto;
  padding: 12rpx 24rpx;
  font-size: var(--font-small);
  box-shadow: none;
}

/* Fixed-height button beside inputs — do not use size="mini" (breaks centering) */
.inline-btn {
  width: auto !important;
  height: 88rpx;
  min-height: 88rpx;
  padding: 0 28rpx !important;
  line-height: 88rpx;
  font-size: var(--font-body);
  font-weight: 600;
}

.secondary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 28rpx;
  background: var(--btn-secondary-bg);
  color: #374151;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: var(--font-caption);
  font-weight: 500;
}

.secondary-btn:active {
  background: var(--btn-secondary-bg-active);
}

.secondary-btn::after {
  border: none;
}

.secondary-btn[size="mini"] {
  padding: 12rpx 20rpx;
  font-size: var(--font-small);
}

/* Low-key positive action (e.g. complete task) */
.soft-success-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 28rpx;
  background: var(--btn-success-bg);
  color: var(--color-success);
  border: 1rpx solid var(--btn-success-border);
  border-radius: var(--radius-md);
  font-size: var(--font-caption);
  font-weight: 500;
}

.soft-success-btn:active {
  background: #d1fae5;
}

.soft-success-btn::after {
  border: none;
}

.soft-success-btn[size="mini"] {
  padding: 12rpx 20rpx;
  font-size: var(--font-small);
}

.danger-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx 32rpx;
  background: var(--color-danger-bg);
  color: var(--color-danger);
  border: 1rpx solid #fecaca;
  border-radius: var(--radius-md);
  font-size: var(--font-body);
  font-weight: 500;
}

.danger-btn::after {
  border: none;
}

.danger-btn[size="mini"] {
  padding: 12rpx 20rpx;
  font-size: var(--font-small);
}

.menu-list {
  padding: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx var(--space-card);
  border-bottom: 1rpx solid var(--color-border-light);
  font-size: var(--font-body);
  color: var(--color-text);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f9fafb;
}

.menu-chevron {
  color: var(--color-text-muted);
  font-size: 36rpx;
  line-height: 1;
}

.hero-gradient {
  background: linear-gradient(135deg, #6366f1 0%, #9333ea 100%);
  border: none;
  color: #ffffff;
}

.hero-gradient .section-title,
.hero-gradient .section-desc {
  color: #ffffff;
}

.hero-gradient .section-desc {
  opacity: 0.88;
}

.stat-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.stat-item {
  width: calc(50% - 8rpx);
  background: #f9fafb;
  border: 1rpx solid var(--color-border-light);
  border-radius: var(--radius-md);
  padding: 24rpx;
  box-sizing: border-box;
}

.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  font-size: var(--font-small);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.progress-bar {
  height: 12rpx;
  background: var(--color-border-light);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #6366f1, #9333ea);
  border-radius: var(--radius-full);
}

.search-header {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  pointer-events: none;
}

.search-toggle {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  padding: 8rpx var(--space-page);
  background: transparent;
  pointer-events: auto;
}

.search-chevron {
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1;
  transition: transform 0.34s cubic-bezier(0.25, 0.1, 0.25, 1);
  text-shadow: 0 0 8rpx rgba(255, 255, 255, 0.95), 0 1rpx 2rpx rgba(255, 255, 255, 0.8);
}

.search-chevron.open {
  transform: rotate(180deg);
}

.search-filter-tag {
  font-size: 20rpx;
  color: var(--color-primary);
  background: var(--color-primary-light);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-full);
}

.search-panel-wrap {
  overflow: hidden;
  max-height: 0;
  opacity: 0;
  transform: translateY(-8rpx) scale(0.99);
  transform-origin: top right;
  margin: 0 var(--space-page);
  pointer-events: none;
  transition:
    max-height 0.38s cubic-bezier(0.25, 0.1, 0.25, 1),
    opacity 0.34s cubic-bezier(0.25, 0.1, 0.25, 1),
    transform 0.38s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.search-panel-wrap.active {
  max-height: 160rpx;
  opacity: 1;
  transform: translateY(0) scale(1);
  pointer-events: auto;
}

.search-panel-wrap.todos-search.active {
  max-height: 380rpx;
}

.search-panel-wrap.daily-search.active {
  max-height: 140rpx;
}

.search-panel-wrap.closing {
  max-height: 0;
  opacity: 0;
  transform: translateY(-10rpx) scale(0.985);
  pointer-events: none;
}

.search-dismiss-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 9;
  pointer-events: auto;
  background: rgba(15, 23, 42, 0.03);
}

.search-panel {
  margin: 0;
  pointer-events: auto;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.82) 0%,
    rgba(255, 255, 255, 0.68) 100%
  );
  backdrop-filter: saturate(180%) blur(24px);
  -webkit-backdrop-filter: saturate(180%) blur(24px);
  border: 1rpx solid rgba(255, 255, 255, 0.95);
  border-radius: var(--radius-lg);
  padding: var(--space-card);
  box-shadow:
    0 8rpx 32rpx rgba(15, 23, 42, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.compose-fab {
  position: fixed;
  right: var(--space-page);
  bottom: calc(var(--tab-bar-inset) + 12rpx);
  z-index: 100;
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-full);
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid var(--color-border);
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
}

.compose-fab-icon {
  font-size: 40rpx;
  line-height: 1;
  color: var(--color-text-muted);
  font-weight: 300;
  margin-top: -2rpx;
}
