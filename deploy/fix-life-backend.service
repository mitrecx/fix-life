[Unit]
Description=Fix Life Backend API
After=network.target postgresql.service

[Service]
Type=notify
User=josie
Group=josie
WorkingDirectory=/opt/fix-life/backend
Environment="PATH=/opt/fix-life/backend/.venv/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=/opt/fix-life/backend/.venv/bin/gunicorn -w 4 -k uvicorn.workers.UvicornWorker -b 127.0.0.1:8001 app.main:app
ExecReload=/bin/kill -s HUP \$MAINPID
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target