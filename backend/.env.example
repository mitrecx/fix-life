# 可选: 在同目录创建 .env.local（勿提交），会覆盖本文件中同名变量，便于本地开发共用一份 .env 模板。
# 参见 .env.local.example

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:6432/database_name

# JWT Configuration
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS Configuration
CORS_ORIGINS=["http://localhost:5277", "http://localhost:5174"]

# Frontend Configuration
# 前端访问地址，用于邮件通知中的链接
# 本地开发使用 http://localhost:5277
# 生产环境应配置为实际的域名，例如: https://your-domain.com
FRONTEND_URL=http://localhost:5277

# SMTP Email Configuration (163 邮箱示例)
# 其他邮箱服务商配置请参考:
# - Gmail: smtp.gmail.com:587 (TLS) 或 smtp.gmail.com:465 (SSL)
# - QQ: smtp.qq.com:465 (SSL)
# - 163: smtp.163.com:465 (SSL)
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your-email@163.com
SMTP_PASSWORD=your-authorization-code-here
SMTP_FROM=your-email@163.com
SMTP_USE_SSL=true
SMTP_USE_TLS=false
